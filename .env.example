# Application
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
SERVICE_VERSION=

# Logging
LOG_ENABLED=true
LOG_LEVEL=info
LOG_FORMAT=pino-pretty

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DATABASE=forms-manager

# Proxies (leave blank if not required)
HTTP_PROXY=
CDP_HTTPS_PROXY=

# Feature flags
ENABLE_SECURE_CONTEXT=false
ENABLE_METRICS=false
FEATURE_FLAG_PUBLISH_AUDIT_EVENTS=false
FEATURE_FLAG_USE_ENTITLEMENT_API=false

# Tracing
TRACING_HEADER=x-cdp-request-id

# AWS
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3
FORM_DEF_BUCKET_NAME=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# SNS
SNS_ENDPOINT=
SNS_TOPIC_ARN=

# OIDC / JWT authentication
# These values can be found in your Azure AD / OIDC provider configuration.
OIDC_JWKS_URI=
OIDC_VERIFY_AUD=
OIDC_VERIFY_ISS=
ROLE_EDITOR_GROUP_ID=

# Entitlements
ENTITLEMENT_URL=http://localhost:3004

# Encryption
# Base64-encoded RSA public key used to encrypt secrets.
PUBLIC_KEY_FOR_SECRETS=
